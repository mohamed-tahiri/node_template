{
  "extends": "@tsconfig/node20/tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src", 
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true, 
    "types": ["jest"] 
},
  "include": [
    "src/**/*",
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}